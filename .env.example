# ============================================
# BACKEND - Variables de Entorno (PLANTILLA)
# ============================================
# Copiar a .env.local o .env.production y completar valores reales
# NUNCA subir archivos con secretos reales al repositorio

# --- Perfil de ejecución ---
SPRING_PROFILES_ACTIVE=local

# --- Aplicación ---
APP_NAME=colegio-rp-api
APP_PORT=8080
APP_BASE_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Base de datos PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=colegio_rp
DB_USER=colegio_user
DB_PASSWORD=CHANGE_ME

# --- Seguridad JWT ---
JWT_SECRET=CHANGE_ME_USE_LONG_RANDOM_STRING_MIN_64_CHARS
JWT_EXPIRATION_MINUTES=60
JWT_REFRESH_EXPIRATION_DAYS=7

# --- Stripe (pagos) ---
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_PUBLISHABLE_KEY=pk_test_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=CHANGE_ME

# --- Logging ---
LOG_LEVEL=INFO
